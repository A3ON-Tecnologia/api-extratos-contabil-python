# ============================================================
# CONFIGURAÇÕES DA API DE EXTRATOS CONTÁBEIS
# ============================================================
# Este é um arquivo de exemplo. Copie para .env e preencha com seus valores reais.

# ==================== OpenAI / LLM ====================
# API Key da OpenAI para análise inteligente de documentos
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Modelo LLM a usar (gpt-4o-mini, gpt-4o, gpt-4-turbo, etc)
LLM_MODEL=gpt-4o-mini

# ==================== Caminhos do Sistema ====================
# Diretório base onde estão as pastas dos clientes
BASE_PATH=J:\JP Digital

# Planilha com a relação de clientes e CNPJs
CLIENTS_EXCEL_PATH=J:\JP Digital\000 - AUTOMAÇÕES\RELAÇÃO EXTRATOS.xlsx

# Planilha de log (legado - mantida por compatibilidade)
LOG_EXCEL_PATH=J:\JP Digital\000 - AUTOMAÇÕES\LOGS SUCESSO _ FALHA.xlsx

# ==================== Extratos - Processamento Automático ====================
# Planilha Excel com a relação dos extratos esperados
EXTRATOS_EXCEL_PATH=J:\JP Digital\000 - AUTOMAÇÕES\RELAÇÃO EXTRATOS.xlsx

# Pasta monitorada para extratos de entrada (watcher)
# Arquivos PDF/ZIP depositados aqui serão processados automaticamente
WATCH_FOLDER_PATH=\\jpdc2\Dados$\J:\JP Digital\000 - AUTOMAÇÕES\EXTRATOS

# ==================== Configurações de Matching ====================
# Threshold de similaridade para match por nome (0-100)
# Quanto maior, mais rigoroso o matching
# Valores recomendados: 80-85 (flexível), 85-90 (equilibrado), 90-95 (rigoroso)
SIMILARITY_THRESHOLD=85

# ==================== Servidor ====================
# Porta em que a API será executada
PORT=8888

# ==================== Banco de Dados MySQL ====================
# Configurações do banco MySQL para armazenamento de logs
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=sua_senha_aqui
DB_NAME=extratos_contabil_python
